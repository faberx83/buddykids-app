# Credenziali degli account di TEST usati da test-deploy.sh (Playwright)
# contro il deploy reale — copia questo file in ".env.test" (gitignored) e
# compila con account VERI già promossi ai ruoli giusti (vedi README.md,
# sezione "Promuovere un utente a Gestore centro o Admin piattaforma").
#
# Consiglio: usa account dedicati SOLO al testing (es. test.genitore@...),
# non i tuoi account reali — i test di scrittura (prenotazioni, gruppi,
# attività...) creano dati veri nel database di produzione con questi
# account, quindi meglio poterli riconoscere/pulire facilmente.

# NOTA: usa un dominio email VERO (con MX validi), altrimenti Supabase
# rifiuta la registrazione con "invalid mail" — @buddykids.it non è un
# dominio email reale. Un trucco comodo: usa il tuo indirizzo con alias "+"
# (se il tuo provider li supporta, es. Gmail): arrivano tutti nella tua
# stessa casella e li riconosci subito nell'elenco.
TEST_PARENT_EMAIL=faberx83+test-genitore@gmail.com
TEST_PARENT_PASSWORD=

TEST_CENTER_ADMIN_EMAIL=faberx83+test-gestore@gmail.com
TEST_CENTER_ADMIN_PASSWORD=

TEST_PLATFORM_ADMIN_EMAIL=faberx83@gmail.com
TEST_PLATFORM_ADMIN_PASSWORD=

# Necessarie per la pulizia automatica dei dati di test prima di ogni run
# (tests/cleanup-test-data.mjs) — vedi quel file per i dettagli.
# NEXT_PUBLIC_SUPABASE_URL: la stessa usata dall'app (Project Settings > API).
# SUPABASE_SERVICE_ROLE_KEY: chiave SEGRETA (Project Settings > API >
#   service_role) — bypassa la RLS, non condividerla, non usarla nel codice
#   app. Se la lasci vuota, la pulizia viene semplicemente saltata.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
