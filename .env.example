# Supabase — inserisci qui le tue chiavi
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sprint 8 — solo per l'endpoint interno app/internal/beta-pipeline
# (automazione "BETA feedback -> pipeline"). MAI con prefisso NEXT_PUBLIC_:
# vanno impostate SOLO nelle variabili d'ambiente del progetto su Vercel,
# mai in un .env.local che finisce nel bundle client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PIPELINE_AUTOMATION_SECRET=un-valore-lungo-e-casuale-a-tua-scelta

# ────────────────────────────────────────────────────────────────
# Multi-tenant a sottodomini (proxy.ts, lib/tenant.ts) — già in uso nel
# codice, aggiunte qui perché mancanti da questo file (gap documentale
# preesistente individuato nella baseline TRAMA ONE, non introdotto da
# questo sprint). Tutte opzionali: senza alias .vercel.app "sciolti" (solo
# pattern partner./admin.<dominio> reale) non servono.
NEXT_PUBLIC_PARTNER_HOSTS=buddykids-partner.vercel.app
NEXT_PUBLIC_ADMIN_HOSTS=buddykids-admin.vercel.app
# Necessario solo con alias .vercel.app "sciolti" (non sottodomini dello
# stesso dominio): indica esplicitamente l'host del dominio famiglie a cui
# tornare quando un utente autenticato ha il ruolo sbagliato per partner./admin.
NEXT_PUBLIC_MAIN_HOST=buddykids-app.vercel.app
# Necessario solo se si vuole condividere il cookie di sessione Supabase tra
# sottodomini di uno stesso dominio reale (es. .buddykids.app) — lascia vuoto
# con alias .vercel.app separati (i cookie non sono comunque condivisibili tra
# host .vercel.app distinti).
NEXT_PUBLIC_COOKIE_DOMAIN=

# Inviti Famiglia (app/actions/invites.ts) — mittente delle email di invito.
RESEND_API_KEY=your-resend-api-key
INVITE_FROM_EMAIL=inviti@tuodominio.it

# ────────────────────────────────────────────────────────────────
# TRAMA ONE Build Sprint 0 — Feature Flag Engine
#
# Nessuna nuova variabile d'ambiente dedicata: lo scope "environment" del
# resolver (lib/feature-flags/resolve.ts) riusa VERCEL_ENV (già impostata
# automaticamente da Vercel: "production"/"preview"/"development") con
# fallback a NODE_ENV in locale — nessuna azione richiesta qui.
#
# TRAMA_ONE_ENABLED NON è una variabile d'ambiente: è un flag risolto
# esclusivamente server-side da lib/feature-flags/resolve.ts, con gli
# override persistiti in Supabase (tabella feature_flag_overrides, vedi
# supabase/migration_07_feature_flags_foundation.sql). Non deve MAI comparire
# qui come NEXT_PUBLIC_TRAMA_ONE_ENABLED o simili: nessuna esposizione al
# bundle client è prevista né ammessa.
