# Supabase — inserisci qui le tue chiavi
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sprint 8 — solo per l'endpoint interno app/internal/beta-pipeline
# (automazione "BETA feedback -> pipeline"). MAI con prefisso NEXT_PUBLIC_:
# vanno impostate SOLO nelle variabili d'ambiente del progetto su Vercel,
# mai in un .env.local che finisce nel bundle client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PIPELINE_AUTOMATION_SECRET=un-valore-lungo-e-casuale-a-tua-scelta
